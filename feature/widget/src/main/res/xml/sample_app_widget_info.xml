<?xml version="1.0" encoding="utf-8"?>
<appwidget-provider 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:initialLayout="@layout/widget_initial"
    android:previewImage="@drawable/ic_widget_foreground"
    android:description="@string/widget_description"
    android:minWidth="180dp"
    android:minHeight="180dp"
    android:minResizeWidth="120dp"
    android:minResizeHeight="120dp"
    android:targetCellWidth="3"
    android:targetCellHeight="2"
    android:maxResizeWidth="400dp"
    android:maxResizeHeight="400dp"
    android:updatePeriodMillis="86400000"
    android:resizeMode="horizontal|vertical"
    android:configure="com.cyy.android.widget.WidgetConfigureActivity"
    android:widgetFeatures="reconfigurable|configuration_optional"

    android:widgetCategory="home_screen" />
